{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/CLI/CLI.csproj"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "run-unit-tests",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/tests/UnitTests/UnitTests.csproj"
            ],
            "problemMatcher": "$msCompile",
            "group": "test"
        },
        {
            "label": "docker-build-integration",
            "type": "process",
            "command": "docker",
            "args": ["build", "-t", "b-branch-integration-tests", "."],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "docker-run-integration",
            "type": "process",
            "command": "docker",
            "args": ["run", "--rm", "b-branch-integration-tests"]
        },
        {
            "label": "run-integration-tests",
            "dependsOn": [
                "docker-build-integration",
                "docker-run-integration"
            ],
            "dependsOrder": "sequence",
            "group": "test"
        },
        {
            "label": "aot-test-build",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "publish",
                "${workspaceFolder}/src/Cli/Cli.csproj",
                "-r",
                "win-x64",
                "-c",
                "Release",
                "-o",
                "${workspaceFolder}/aot-test-build"
            ],
            "group": "build"
        }
    ]
}
